# Supabase — copy this file to .env.local and fill in your project values.
# For local dev (supabase start): use the values printed by `npm run supabase:status`.
# For cloud: use the URL and keys from your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Mapbox — required for round tracking map view
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token
